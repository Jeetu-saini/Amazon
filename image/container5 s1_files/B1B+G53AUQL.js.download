 context: (string; optional) }\n\n    // Currently, CloudWatch can't aggregate metrics by a subset of dimensions.\n    // To bypass this limitation, we introduce the optional dimensions concept to CSM.\n    // The CSM metric publisher will publish a default metric without optional dimension\n    // For each optional dimension, the CSM metric publisher publishes an extra metric with that dimension.\n    this.optionalDimensions \x3d csm.globalOptionalDimensions ? csm.Util.deepCopy(csm.globalOptionalDimensions): [];\n  };\n\n  Metric.prototype.addDimension \x3d function(name, value) {\n    this._addDimensionHelper(this.dimensions, name, value);\n  };\n\n  Metric.prototype.addOptionalDimension \x3d function(name, value) {\n    this._addDimensionHelper(this.optionalDimensions, name, value);\n  };\n\n  Metric.prototype._addDimensionHelper \x3d function(targetDimensions, name, value) {\n    // CloudWatch metric allows maximum 10 dimensions\n    // http://docs.aws.amazon.com/AWSJavaScriptSDK/latest/AWS/CloudWatch.html#putMetricData-property\n    if ((this.dimensions.length + this.optionalDimensions.length) \x3e\x3d MAX_METRIC_DIMENSIONS) {\n      throw new csm.ExceedDimensionLimitException(name);\n    }\n\n    const existing \x3d targetDimensions.find(function(dimension) {\n      return dimension.name \x3d\x3d\x3d name;\n    });\n\n    if (existing) {\n      existing.value \x3d value \x3d\x3d null ? 'null' : (value \x3d\x3d\x3d '' ? ' ' : value.toString());\n    } else {\n      targetDimensions.push(new Dimension(name, value));\n    }\n  };\n\n\n  /** ********* Telemetry Classes ***********/\n\n  const WorkflowEvent \x3d function(params) {\n    this.timestamp \x3d params.timestamp || new Date().getTime();\n    this.workflowType \x3d params.workflow.type;\n    this.instanceId \x3d params.workflow.instanceId;\n    this.userId \x3d params.userId;\n    this.organizationId \x3d params.organizationId;\n    this.accountId \x3d params.accountId;\n    this.event \x3d params.event;\n    this.appName \x3d params.appName;\n    this.data \x3d [];\n\n    // Convert 'data' map into the KeyValuePairList structure expected by the Lambda API\n    for (const key in params.data) {\n      if (Object.prototype.hasOwnProperty.call(params.data, key)) {\n        this.data.push({'key': key, 'value': params.data[key]});\n      }\n    }\n  };\n\n  /** ********* Exceptions ***********/\n\n  const NullOrUndefinedException \x3d function(paramName) {\n    this.name \x3d 'NullOrUndefinedException';\n    this.message \x3d paramName + ' is null or undefined. ';\n  };\n  NullOrUndefinedException.prototype.toString \x3d function() {\n    return this.name + ': ' + this.message;\n  };\n\n  const AssertTrueException \x3d function() {\n    this.name \x3d 'AssertTrueException';\n    this.message \x3d 'Assertion failed. ';\n  };\n  AssertTrueException.prototype.toString \x3d function() {\n    return this.name + ': ' + this.message;\n  };\n\n  const ExceedDimensionLimitException \x3d function(dimensionName) {\n    this.name \x3d 'ExceedDimensionLimitException';\n    this.message \x3d 'Could not add dimension \\'' + dimensionName + '\\'. Metric has maximum 10 dimensions. ';\n  };\n  ExceedDimensionLimitException.prototype.toString \x3d function() {\n    return this.name + ': ' + this.message;\n  };\n\n  const InitializationException \x3d function() {\n    this.name \x3d 'InitializationException';\n    this.message \x3d 'Initialization failed. ';\n  };\n  InitializationException.prototype.toString \x3d function() {\n    return this.name + ': ' + this.message;\n  };\n\n\n  csm.Dimension \x3d Dimension;\n  csm.Metric \x3d Metric;\n  csm.WorkflowEvent \x3d WorkflowEvent;\n  csm.NullOrUndefinedException \x3d NullOrUndefinedException;\n  csm.AssertTrueException \x3d AssertTrueException;\n  csm.InitializationException \x3d InitializationException;\n  csm.ExceedDimensionLimitException \x3d ExceedDimensionLimitException;\n})();\n\n(function() {\n  const global \x3d self;\n  const csm \x3d global.csm || {};\n  global.csm \x3d csm;\n\n  const validTimeUnits \x3d [csm.UNIT.SECONDS, csm.UNIT.MILLISECONDS, csm.UNIT.MICROSECONDS];\n  const validUnits \x3d validTimeUnits.concat(csm.UNIT.COUNT);\n\n  const Util \x3d {\n    assertExist: function(value, paramName) {\n      if (value \x3d\x3d\x3d null || value \x3d\x3d\x3d undefined) {\n        throw new csm.NullOrUndefinedException(paramName);\n      }\n    },\n    assertTrue: function(value) {\n      if (!value) {\n        throw new csm.AssertTrueException();\n      }\n    },\n    assertInObject: function(obj, objName, key) {\n      if (obj \x3d\x3d\x3d null || obj \x3d\x3d\x3d undefined || typeof obj !\x3d\x3d 'object') {\n        throw new csm.NullOrUndefinedException(objName);\n      }\n      if (key \x3d\x3d\x3d null || key \x3d\x3d\x3d undefined || !obj[key]) {\n        throw new csm.NullOrUndefinedException(`${objName}[${key}]`);\n      }\n    },\n    isValidUnit: function(unit) {\n      return validUnits.includes(unit);\n    },\n    isValidTimeUnit: function(unit) {\n      return validTimeUnits.includes(unit);\n    },\n    isEmpty: function(value) {\n      if (value !\x3d\x3d null \x26\x26 typeof val \x3d\x3d\x3d 'object') {\n        return Objects.keys(value).length \x3d\x3d\x3d 0;\n      }\n      return !value;\n    },\n    deepCopy: function(obj) {\n      // NOTE: this will fail if obj has a circular reference\n      return JSON.parse(JSON.stringify(obj));\n    },\n\n    /**\n     * This function is used before setting the page location for default metrics and logs,\n     * and the APIs that set page location\n     * Can be overridden by calling csm.API.setPageLocationTransformer(function(){})\n     * @param {string}        pathname path for page location\n     * @return {string}       pathname provided\n     */\n    pageLocationTransformer: function(pathname) {\n      return pathname;\n    },\n\n    /**\n     * As of now, our service public claims only support for Firefox and Chrome\n     * Reference https://developer.mozilla.org/en-US/docs/Web/HTTP/Browser_detection_using_the_user_agent\n     *\n     * This function will only return firefox, chrome and others\n     *\n     * Best practice as indicated in MDN, \"Avoiding user agent detection\"\n     */\n    getBrowserDetails: function() {\n      const userAgent \x3d window.navigator.userAgent;\n      const details \x3d {};\n      if (userAgent.includes('Firefox') \x26\x26 !userAgent.includes('Seamonkey')) {\n        details.name \x3d 'Firefox';\n        details.version \x3d getBrowserVersion('Firefox');\n      } else if (userAgent.includes('Chrome') \x26\x26 !userAgent.includes('Chromium')) {\n        details.name \x3d 'Chrome';\n        details.version \x3d getBrowserVersion('Chrome');\n      }\n    },\n\n    randomId: function() {\n      return new Date().getTime() + '-' + Math.random().toString(36).slice(2);\n    },\n\n    getOrigin: function() {\n      return document.location.origin;\n    },\n\n    getReferrerUrl: function() {\n      const referrer \x3d document.referrer || '';\n      return this.getURLOrigin(referrer);\n    },\n\n    getWindowParent: function() {\n      let parentLocation \x3d '';\n      try {\n        parentLocation \x3d window.parent.location.href;\n      } catch (e) {\n        parentLocation \x3d '';\n      }\n      return parentLocation;\n    },\n\n    getURLOrigin: function(urlValue) {\n      let origin \x3d '';\n      const originArray \x3d urlValue.split( '/' );\n      if (originArray.length \x3e\x3d 3) {\n        const protocol \x3d originArray[0];\n        const host \x3d originArray[2];\n        origin \x3d protocol + '//' + host;\n      }\n      return origin;\n    },\n\n  };\n\n  const getBrowserVersion \x3d function(browserName) {\n    const userAgent \x3d window.navigator.userAgent;\n    const browserNameIndex \x3d userAgent.indexOf(browserName);\n    const nextSpaceIndex \x3d userAgent.indexOf(' ', browserNameIndex);\n    if (nextSpaceIndex \x3d\x3d\x3d -1) {\n      return userAgent.substring(browserNameIndex + browserName.length + 1, userAgent.length);\n    } else {\n      return userAgent.substring(browserNameIndex + browserName.length + 1, nextSpaceIndex);\n    }\n  };\n\n  csm.Util \x3d Util;\n})();\n\n(function() {\n  const global \x3d window;\n  const csm \x3d global.csm || {};\n  global.csm \x3d csm;\n\n  csm.globalDimensions \x3d []; // These dimensions are added to all captured metrics.\n  csm.globalOptionalDimensions \x3d [];\n  csm.initFailureDimensions \x3d [];\n\n  const API \x3d {\n    getWorkflow: function(workflowType, instanceId, data) {\n      return csm.workflow(workflowType, instanceId, data);\n    },\n\n    addMetric: function(metric) {\n      csm.Util.assertExist(metric, 'metric');\n      csm.putMetric(metric);\n    },\n\n    addMetricWithDedupe: function(metric, dedupeIntervalMs, context) {\n      csm.Util.assertExist(metric, 'metric');\n      csm.Util.assertExist(metric, 'dedupeIntervalMs');\n      // context is optional; if present it will only dedupe on metrics with the same context. ex.) tabId\n      metric.dedupeOptions \x3d {dedupeIntervalMs, context: context || 'global'};\n      csm.putMetric(metric);\n    },\n\n    addCount: function(metricName, count) {\n      csm.Util.assertExist(metricName, 'metricName');\n      csm.Util.assertExist(count, 'count');\n\n      const metric \x3d new csm.Metric(metricName, csm.UNIT.COUNT, count);\n      csm.putMetric(metric);\n    },\n\n    addCountWithPageLocation: function(metricName) {\n      csm.Util.assertExist(metricName, 'metricName');\n\n      const metric \x3d new csm.Metric(metricName, csm.UNIT.COUNT, 1.0);\n      metric.addDimension('WindowLocation', csm.Util.pageLocationTransformer(window.location.pathname));\n      csm.putMetric(metric);\n    },\n\n    addError: function(metricName, count) {\n      csm.Util.assertExist(metricName, 'metricName');\n\n      if (count \x3d\x3d\x3d undefined || count \x3d\x3d null) {\n        count \x3d 1.0;\n      }\n      const metric \x3d new csm.Metric(metricName, csm.UNIT.COUNT, count);\n      metric.addDimension('Metric', 'Error');\n      csm.putMetric(metric);\n    },\n\n    addSuccess: function(metricName) {\n      API.addError(metricName, 0);\n    },\n\n    addTime: function(metricName, time, unit) {\n      csm.Util.assertExist(metricName, 'metricName');\n      csm.Util.assertExist(time, 'time');\n\n      let timeUnit \x3d csm.UNIT.MILLISECONDS;\n      if (unit \x26\x26 csm.Util.isValidTimeUnit(unit)) {\n        timeUnit \x3d unit;\n      }\n      const metric \x3d new csm.Metric(metricName, timeUnit, time);\n      metric.addDimension('Metric', 'Time');\n      csm.putMetric(metric);\n    },\n\n    addTimeWithPageLocation: function(metricName, time, unit) {\n      csm.Util.assertExist(metricName, 'metricName');\n      csm.Util.assertExist(time, 'time');\n\n      let timeUnit \x3d csm.UNIT.MILLISECONDS;\n      if (unit \x26\x26 csm.Util.isValidTimeUnit(unit)) {\n        timeUnit \x3d unit;\n      }\n      const metric \x3d new csm.Metric(metricName, timeUnit, time);\n      metric.addDimension('WindowLocation', csm.Util.pageLocationTransformer(window.location.pathname));\n      csm.putMetric(metric);\n    },\n\n    pageReady: function() {\n      if (window.performance \x26\x26 window.performance.now) {\n        const pageLoadTime \x3d window.performance.now();\n        const metric \x3d new csm.Metric('PageReadyLatency', csm.UNIT.MILLISECONDS, pageLoadTime);\n        metric.addDimension('WindowLocation', csm.Util.pageLocationTransformer(window.location.pathname));\n        csm.putMetric(metric);\n      }\n    },\n\n    setPageLocationTransformer: function(transformFunc) {\n      csm.Util.assertExist(transformFunc, 'transformFunc');\n      csm.Util.assertTrue((typeof transformFunc) \x3d\x3d\x3d 'function');\n      csm.Util.pageLocationTransformer \x3d transformFunc;\n    },\n\n    setGlobalDimensions: function(dimensions) {\n      csm.Util.assertExist(dimensions, 'dimensions');\n   